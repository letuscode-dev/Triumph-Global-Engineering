# ============================================================
# Triumph Global Engineering — Environment Variables
# Copy this file to ".env.local" and fill in your values.
# The site runs with built-in demo data even if these are blank.
# ============================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.triumphglobal.co.zw

# --- Supabase (backend, database, auth) ---
# Get these from https://app.supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only key (NEVER expose to the browser). Used by API routes.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres URL for running migrations locally (optional).
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Cloudinary (image & video storage) ---
# Get these from https://cloudinary.com -> Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Admin dashboard ---
# Initial admin password (dev only). Change via /admin/settings in production.
ADMIN_PASSWORD=
# Random secret used to sign the admin session cookie (set a long random string).
ADMIN_SESSION_TOKEN=

# --- Contact / Leads ---
# Where quote requests & contact form submissions are emailed.
LEADS_NOTIFY_EMAIL=info@triumphglobal.co.zw
# Email delivery via Resend (https://resend.com). Leave blank to disable email
# (leads are still captured in the dashboard / database).
RESEND_API_KEY=
RESEND_FROM=Triumph Global <onboarding@resend.dev>

# --- Rate limiting (optional) ---
# If set, the leads API uses Upstash Redis so limits work across multiple
# serverless instances. Leave blank to use the built-in in-memory limiter.
# Get these from https://console.upstash.com -> Redis -> REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Integrations ---
NEXT_PUBLIC_WHATSAPP_NUMBER=263779651626
# Google Analytics. When set, a cookie-consent banner is shown and GA only
# loads after the visitor accepts.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED=
